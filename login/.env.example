# URL base do Zitadel — usada APENAS para o fallback de Login V1 (auth requests
# de outros clientes, como o console). As chamadas à Session API NÃO batem
# nessa URL direto: passam pelo Vite proxy /zitadel-api/* que injeta o Bearer
# do login-client PAT (segredo nunca toca o bundle do browser).
VITE_ZITADEL_AUTHORITY=http://localhost:8088

# Base same-origin que o cliente JS usa para falar com o Zitadel. Em dev é o
# proxy do Vite (config em vite.config.ts). Sobrescreva apenas se você tiver
# outro gateway autenticando por você.
VITE_ZITADEL_API_BASE=/zitadel-api

# Upstream real do proxy (lado servidor — usado por vite.config.ts).
VITE_ZITADEL_UPSTREAM=http://localhost:8088

# Client ID do app Web principal (TKWS OS → Projects → Web → Client Id).
# Usado para detectar se o auth request é do app principal ou de outra aplicação
# (ex: console do Zitadel). Se o request for de outro cliente, o login customizado
# redireciona silenciosamente para o Login V1 do Zitadel.
VITE_ZITADEL_CLIENT_ID=

# ID da organização no Zitadel (obtido em Console > Organization > Settings)
# Necessário para requests de reset de senha via Session API
VITE_ZITADEL_ORG_ID=

# ID do Identity Provider Microsoft configurado no Zitadel
# (Console > Default Settings > Identity Providers > Microsoft > ID).
# Quando vazio, o botão "Continuar com Microsoft" não é exibido.
VITE_ZITADEL_MICROSOFT_IDP_ID=

# URL base desta própria app de login (necessária para CORS)
VITE_LOGIN_BASE_URL=http://localhost:5174

# URL base da API TKWS (Spring Boot). Usada pela tela /accept-invite
# e demais chamadas a endpoints próprios (não-Zitadel).
VITE_API_URL=http://localhost:8080

# Segredo para cifrar credenciais em "Lembrar deste dispositivo" (AES-GCM no browser).
# Use valor longo e aleatório em produção. Não protege contra XSS — só oculta do localStorage em claro.
VITE_LOGIN_STORAGE_PEPPER=499b03996fddcbaf0213e09a0aa0953f022e122b247a89ddba85188ed81a912a
